# -------------------------------
# Strapi basic
# -------------------------------
HOST=0.0.0.0
PORT=1337
APP_KEYS=app-key-1,app-key-2,app-key-3,app-key-4
API_TOKEN_SALT=replace-me
ADMIN_JWT_SECRET=replace-me
TRANSFER_TOKEN_SALT=replace-me
JWT_SECRET=replace-me

# -------------------------------
# Database (sqlite default)
# -------------------------------
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# PostgreSQL を使う場合は以下を有効化
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgres://user:password@host:5432/database
# DATABASE_SSL=false

# -------------------------------
# CORS
# -------------------------------
FRONTEND_URL=https://mizzz.jp,https://store.mizzz.jp,https://fc.mizzz.jp

# -------------------------------
# Logto API authorization
# custom domain (auth.mizzz.jp) はエンドユーザー認証に利用し、
# Management API / M2M は default tenant endpoint を利用する
# -------------------------------
LOGTO_ISSUER=https://your-tenant.logto.app/oidc
LOGTO_JWKS_URI=https://your-tenant.logto.app/oidc/jwks
LOGTO_API_RESOURCE=https://api.mizzz.jp
LOGTO_REQUIRED_SCOPES=
LOGTO_MANAGEMENT_API_ENDPOINT=https://your-tenant.logto.app
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=
LOGTO_USER_SYNC_OPS_TOKEN=replace-with-random-user-sync-ops-token

# -------------------------------
# Health / readiness
# -------------------------------
READINESS_TIMEOUT_MS=2000
CORS_ALLOW_CREDENTIALS=false
AUDIT_IP_HASH_SALT=replace-with-random-audit-salt

# -------------------------------
# Upload / inquiry hardening
# -------------------------------
UPLOAD_MAX_FILE_SIZE_BYTES=10485760
INQUIRY_MAX_FILE_BYTES=10485760
INQUIRY_MAX_FILES=5
INQUIRY_SPAM_WINDOW_MS=600000
INQUIRY_SPAM_MAX_PER_WINDOW=8
INQUIRY_DUPLICATE_WINDOW_MS=90000
INQUIRY_IP_HASH_SALT=replace-with-long-random-salt
INQUIRY_OPS_TOKEN=replace-with-random-ops-token
ANALYTICS_OPS_TOKEN=replace-with-random-analytics-ops-token
ANALYTICS_IP_HASH_SALT=replace-with-long-random-analytics-salt
INQUIRY_REPLY_SLA_DAYS=3

# 通知メール (任意)
INQUIRY_NOTIFY_TO=ops@example.com
INQUIRY_ENABLE_AUTO_REPLY=false

# -------------------------------
# Global rate limit / audit
# -------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUDIT_WINDOW_MS=300000
AUDIT_404_THRESHOLD=20

# -------------------------------
# Mail provider (任意)
# plugins.ts / Strapi Cloud 側設定に合わせて調整
# -------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=user
# SMTP_PASSWORD=pass
# SMTP_FROM=no-reply@mizzz.jp

# -------------------------------
# Billing / subscription sync hardening
# -------------------------------
BILLING_GRACE_PERIOD_DAYS=3
BILLING_SYNC_RETRY_LIMIT=5
BILLING_SYNC_RETRY_DELAY_MS=30000

# -------------------------------
# Store order / fulfillment ops
# -------------------------------
ORDER_NUMBER_PREFIX=MZ
ORDER_WEBHOOK_RETRY_LIMIT=5
ORDER_WEBHOOK_RETRY_DELAY_MS=30000
ORDER_MANUAL_REVIEW_QUEUE_ENABLED=true
INVENTORY_LOW_STOCK_THRESHOLD=5
INVENTORY_RESERVATION_TTL_MS=900000
REVENUE_EXPORT_MAX_ROWS=5000

# -------------------------------
# BI / KPI summary foundation
# -------------------------------
BI_DEFAULT_RANGE_DAYS=30
BI_MAX_FETCH_ROWS=10000
