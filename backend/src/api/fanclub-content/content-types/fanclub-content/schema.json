{
  "kind": "collectionType",
  "collectionName": "fanclub_contents",
  "info": {
    "singularName": "fanclub-content",
    "pluralName": "fanclub-contents",
    "displayName": "Fanclub Post",
    "description": "Fan club exclusive content / ファンクラブ限定コンテンツ"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "publishAt": {
      "type": "datetime"
    },
    "limitedEndAt": {
      "type": "datetime"
    },
    "archiveVisibleForFC": {
      "type": "boolean",
      "default": false
    },
    "body": {
      "type": "richtext"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "diary",
        "exclusive",
        "qa",
        "behind_scenes",
        "teaser",
        "live_archive",
        "tips",
        "info"
      ],
      "default": "diary"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "accessStatus": {
      "type": "enumeration",
      "enum": [
        "public",
        "fc_only",
        "limited"
      ],
      "default": "fc_only",
      "required": true
    },
    "relatedProducts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::store-product.store-product"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "pickup": {
      "type": "boolean",
      "default": false
    },
    "memberBenefit": {
      "type": "text"
    },
    "membersOnlyNotice": {
      "type": "text"
    },
    "earlyAccess": {
      "type": "boolean",
      "default": false
    },
    "specialOffer": {
      "type": "text"
    },
    "campaignLabel": {
      "type": "string"
    },
    "campaignSlug": {
      "type": "string"
    },
    "campaignType": {
      "type": "enumeration",
      "enum": [
        "feature",
        "drop",
        "launch",
        "restock",
        "benefit",
        "announcement"
      ],
      "default": "feature"
    },
    "heroCopy": {
      "type": "text"
    },
    "heroSubcopy": {
      "type": "text"
    },
    "shortHighlight": {
      "type": "text"
    },
    "isTrending": {
      "type": "boolean",
      "default": false
    },
    "isLimited": {
      "type": "boolean",
      "default": false
    },
    "membersOnly": {
      "type": "boolean",
      "default": false
    },
    "displayPriority": {
      "type": "integer",
      "default": 0
    },
    "startAt": {
      "type": "datetime"
    },
    "endAt": {
      "type": "datetime"
    },
    "bannerLink": {
      "type": "string"
    },
    "ctaText": {
      "type": "string"
    },
    "ctaLink": {
      "type": "string"
    },
    "sectionStyle": {
      "type": "string"
    },
    "cardStyleVariant": {
      "type": "string"
    },
    "badgeStyleVariant": {
      "type": "string"
    },
    "backgroundVariant": {
      "type": "string"
    },
    "sectionBackgroundVariant": {
      "type": "string"
    },
    "motionStyle": {
      "type": "string"
    },
    "notifyEnabled": {
      "type": "boolean",
      "default": false
    },
    "notifyType": {
      "type": "enumeration",
      "enum": [
        "weekly_update",
        "campaign",
        "member_early_access",
        "new_content",
        "announcement"
      ],
      "default": "weekly_update"
    },
    "notifyLabel": {
      "type": "string"
    },
    "notificationCopy": {
      "type": "text"
    },
    "isImportant": {
      "type": "boolean",
      "default": false
    },
    "weeklyHighlight": {
      "type": "boolean",
      "default": false
    },
    "dashboardPriority": {
      "type": "integer",
      "default": 0
    },
    "announcementBar": {
      "type": "boolean",
      "default": false
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "heroVisual": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "heroIllustration": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "illustrationAsset": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "editorialWorkflowStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "review_pending",
        "approved",
        "scheduled",
        "published",
        "archived",
        "expired"
      ],
      "default": "draft",
      "required": true
    },
    "editorialChecklist": {
      "type": "json"
    },
    "reviewComment": {
      "type": "text"
    },
    "approvedBy": {
      "type": "string"
    },
    "approvedAt": {
      "type": "datetime"
    },
    "scheduledPublishAt": {
      "type": "datetime"
    },
    "archiveAt": {
      "type": "datetime"
    },
    "qualityScore": {
      "type": "integer",
      "min": 0,
      "max": 100,
      "default": 0
    },
    "qualityWarnings": {
      "type": "json"
    },
    "translationCoverage": {
      "type": "json"
    }
  }
}
