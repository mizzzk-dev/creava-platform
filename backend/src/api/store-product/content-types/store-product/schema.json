{
  "kind": "collectionType",
  "collectionName": "store_products",
  "info": {
    "singularName": "store-product",
    "pluralName": "store-products",
    "displayName": "Store Product",
    "description": "Store products / ストア商品"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["public", "fc_only", "limited"],
      "default": "public",
      "required": true
    },
    "publishAt": {
      "type": "datetime"
    },
    "limitedEndAt": {
      "type": "datetime"
    },
    "archiveVisibleForFC": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "integer",
      "required": true,
      "min": 0
    },
    "currency": {
      "type": "string",
      "default": "JPY",
      "required": true
    },
    "stripeLink": {
      "type": "string"
    },
    "baseLink": {
      "type": "string"
    },
    "purchaseStatus": {
      "type": "enumeration",
      "enum": ["available", "soldout", "coming_soon"],
      "default": "available",
      "required": true
    },
    "externalPurchaseNote": {
      "type": "text"
    },
    "previewImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
