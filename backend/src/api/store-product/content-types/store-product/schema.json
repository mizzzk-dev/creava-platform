{
  "kind": "collectionType",
  "collectionName": "store_products",
  "info": {
    "singularName": "store-product",
    "pluralName": "store-products",
    "displayName": "Store Product",
    "description": "Store products / ストア商品"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "publishAt": {
      "type": "datetime"
    },
    "limitedEndAt": {
      "type": "datetime"
    },
    "archiveVisibleForFC": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "integer",
      "required": true,
      "min": 0
    },
    "stock": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "currency": {
      "type": "string",
      "default": "JPY",
      "required": true
    },
    "sku": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "default": "other"
    },
    "tags": {
      "type": "json"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "isNewArrival": {
      "type": "boolean",
      "default": false
    },
    "pickup": {
      "type": "boolean",
      "default": false
    },
    "memberBenefit": {
      "type": "text"
    },
    "membersOnlyNotice": {
      "type": "text"
    },
    "earlyAccess": {
      "type": "boolean",
      "default": false
    },
    "specialOffer": {
      "type": "text"
    },
    "campaignLabel": {
      "type": "string"
    },
    "campaignSlug": {
      "type": "string"
    },
    "campaignType": {
      "type": "enumeration",
      "enum": [
        "feature",
        "drop",
        "launch",
        "restock",
        "benefit",
        "announcement"
      ],
      "default": "feature"
    },
    "shortHighlight": {
      "type": "text"
    },
    "heroCopy": {
      "type": "text"
    },
    "isTrending": {
      "type": "boolean",
      "default": false
    },
    "isLimited": {
      "type": "boolean",
      "default": false
    },
    "membersOnly": {
      "type": "boolean",
      "default": false
    },
    "displayPriority": {
      "type": "integer",
      "default": 0
    },
    "startAt": {
      "type": "datetime"
    },
    "endAt": {
      "type": "datetime"
    },
    "bannerLink": {
      "type": "string"
    },
    "ctaText": {
      "type": "string"
    },
    "ctaLink": {
      "type": "string"
    },
    "sectionStyle": {
      "type": "string"
    },
    "badgeStyleVariant": {
      "type": "string"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "cautionNotes": {
      "type": "text"
    },
    "shippingNotes": {
      "type": "text"
    },
    "digitalDeliveryNotes": {
      "type": "text"
    },
    "stripeLink": {
      "type": "string"
    },
    "baseLink": {
      "type": "string"
    },
    "purchaseStatus": {
      "type": "enumeration",
      "enum": [
        "available",
        "soldout",
        "coming_soon"
      ],
      "default": "available",
      "required": true
    },
    "externalPurchaseNote": {
      "type": "text"
    },
    "previewImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "accessStatus": {
      "type": "enumeration",
      "enum": [
        "public",
        "fc_only",
        "limited"
      ],
      "default": "public",
      "required": true
    },
    "relatedProducts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::store-product.store-product"
    },
    "relatedNews": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::news-item.news-item"
    },
    "relatedEvents": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event.event"
    },
    "relatedBlogPosts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::blog-post.blog-post"
    },
    "relatedFanclubContents": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::fanclub-content.fanclub-content"
    }
  }
}
