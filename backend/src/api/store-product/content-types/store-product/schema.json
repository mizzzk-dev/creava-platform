{
  "kind": "collectionType",
  "collectionName": "store_products",
  "info": {
    "singularName": "store-product",
    "pluralName": "store-products",
    "displayName": "Store Product",
    "description": "Store products / ストア商品"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "publishAt": {
      "type": "datetime"
    },
    "limitedEndAt": {
      "type": "datetime"
    },
    "archiveVisibleForFC": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "integer",
      "required": true,
      "min": 0
    },
    "stock": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "currency": {
      "type": "string",
      "default": "JPY",
      "required": true
    },
    "sku": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "default": "other"
    },
    "tags": {
      "type": "json"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "isNewArrival": {
      "type": "boolean",
      "default": false
    },
    "pickup": {
      "type": "boolean",
      "default": false
    },
    "memberBenefit": {
      "type": "text"
    },
    "membersOnlyNotice": {
      "type": "text"
    },
    "earlyAccess": {
      "type": "boolean",
      "default": false
    },
    "specialOffer": {
      "type": "text"
    },
    "campaignLabel": {
      "type": "string"
    },
    "campaignSlug": {
      "type": "string"
    },
    "campaignType": {
      "type": "enumeration",
      "enum": [
        "feature",
        "drop",
        "launch",
        "restock",
        "benefit",
        "announcement"
      ],
      "default": "feature"
    },
    "shortHighlight": {
      "type": "text"
    },
    "heroCopy": {
      "type": "text"
    },
    "heroSubcopy": {
      "type": "text"
    },
    "isTrending": {
      "type": "boolean",
      "default": false
    },
    "isLimited": {
      "type": "boolean",
      "default": false
    },
    "membersOnly": {
      "type": "boolean",
      "default": false
    },
    "displayPriority": {
      "type": "integer",
      "default": 0
    },
    "startAt": {
      "type": "datetime"
    },
    "endAt": {
      "type": "datetime"
    },
    "bannerLink": {
      "type": "string"
    },
    "ctaText": {
      "type": "string"
    },
    "ctaLink": {
      "type": "string"
    },
    "sectionStyle": {
      "type": "string"
    },
    "cardStyleVariant": {
      "type": "string"
    },
    "badgeStyleVariant": {
      "type": "string"
    },
    "backgroundVariant": {
      "type": "string"
    },
    "sectionBackgroundVariant": {
      "type": "string"
    },
    "motionStyle": {
      "type": "string"
    },
    "notifyEnabled": {
      "type": "boolean",
      "default": false
    },
    "notifyType": {
      "type": "enumeration",
      "enum": [
        "restock",
        "sale_start",
        "campaign",
        "member_early_access",
        "weekly_update"
      ],
      "default": "restock"
    },
    "notifyLabel": {
      "type": "string"
    },
    "notificationCopy": {
      "type": "text"
    },
    "restockExpectedAt": {
      "type": "datetime"
    },
    "isImportant": {
      "type": "boolean",
      "default": false
    },
    "weeklyHighlight": {
      "type": "boolean",
      "default": false
    },
    "dashboardPriority": {
      "type": "integer",
      "default": 0
    },
    "announcementBar": {
      "type": "boolean",
      "default": false
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "cautionNotes": {
      "type": "text"
    },
    "shippingNotes": {
      "type": "text"
    },
    "digitalDeliveryNotes": {
      "type": "text"
    },
    "stripeProductId": {
      "type": "string"
    },
    "stripePriceId": {
      "type": "string"
    },
    "productType": {
      "type": "enumeration",
      "enum": [
        "digital",
        "physical",
        "ticket",
        "service"
      ],
      "default": "physical"
    },
    "isPurchasable": {
      "type": "boolean",
      "default": true
    },
    "stockStatus": {
      "type": "enumeration",
      "enum": [
        "in_stock",
        "low_stock",
        "out_of_stock"
      ],
      "default": "in_stock"
    },
    "saleStatus": {
      "type": "enumeration",
      "enum": [
        "active",
        "scheduled",
        "ended"
      ],
      "default": "active"
    },
    "metadataKey": {
      "type": "string"
    },
    "stripeLink": {
      "type": "string"
    },
    "baseLink": {
      "type": "string"
    },
    "purchaseStatus": {
      "type": "enumeration",
      "enum": [
        "available",
        "soldout",
        "coming_soon"
      ],
      "default": "available",
      "required": true
    },
    "externalPurchaseNote": {
      "type": "text"
    },
    "previewImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "heroVisual": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "heroIllustration": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "illustrationAsset": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "accessStatus": {
      "type": "enumeration",
      "enum": [
        "public",
        "fc_only",
        "limited"
      ],
      "default": "public",
      "required": true
    },
    "relatedProducts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::store-product.store-product"
    },
    "relatedNews": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::news-item.news-item"
    },
    "relatedEvents": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event.event"
    },
    "relatedBlogPosts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::blog-post.blog-post"
    },
    "relatedFanclubContents": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::fanclub-content.fanclub-content"
    },
    "ogTitle": {
      "type": "string"
    },
    "ogDescription": {
      "type": "text"
    },
    "canonicalUrl": {
      "type": "string"
    },
    "noindex": {
      "type": "boolean",
      "default": false
    },
    "nofollow": {
      "type": "boolean",
      "default": false
    },
    "breadcrumbLabel": {
      "type": "string"
    },
    "structuredDataJson": {
      "type": "json"
    },
    "editorialWorkflowStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "review_pending",
        "approved",
        "scheduled",
        "published",
        "archived",
        "expired"
      ],
      "default": "draft",
      "required": true
    },
    "editorialChecklist": {
      "type": "json"
    },
    "reviewComment": {
      "type": "text"
    },
    "approvedBy": {
      "type": "string"
    },
    "approvedAt": {
      "type": "datetime"
    },
    "scheduledPublishAt": {
      "type": "datetime"
    },
    "archiveAt": {
      "type": "datetime"
    },
    "qualityScore": {
      "type": "integer",
      "min": 0,
      "max": 100,
      "default": 0
    },
    "qualityWarnings": {
      "type": "json"
    },
    "translationCoverage": {
      "type": "json"
    }
  }
}
