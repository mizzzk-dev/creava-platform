{
  "kind": "singleType",
  "collectionName": "site_setting",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Settings",
    "description": "Global site settings / サイト全体設定"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "logoUrl": {
      "type": "string"
    },
    "heroTitle": {
      "type": "string"
    },
    "heroSubtitle": {
      "type": "text"
    },
    "heroCopy": {
      "type": "text"
    },
    "heroSubcopy": {
      "type": "text"
    },
    "heroCTALabel": {
      "type": "string"
    },
    "heroCTAUrl": {
      "type": "string"
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "socialInstagram": {
      "type": "string"
    },
    "socialX": {
      "type": "string"
    },
    "socialYoutube": {
      "type": "string"
    },
    "announcementText": {
      "type": "string"
    },
    "announcementUrl": {
      "type": "string"
    },
    "announcementLevel": {
      "type": "enumeration",
      "enum": [
        "info",
        "urgent"
      ],
      "default": "info"
    },
    "announcementBadge": {
      "type": "enumeration",
      "enum": [
        "new",
        "important",
        "members",
        "early"
      ],
      "default": "new"
    },
    "announcementSecondaryText": {
      "type": "string"
    },
    "weeklyHighlightTitle": {
      "type": "string"
    },
    "weeklyHighlightText": {
      "type": "string"
    },
    "weeklyHighlightUrl": {
      "type": "string"
    },
    "topPageSections": {
      "type": "json"
    },
    "heroVisual": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "heroIllustration": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "illustrationAsset": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "sectionBackgroundVariant": {
      "type": "string"
    },
    "backgroundVariant": {
      "type": "string"
    },
    "motionStyle": {
      "type": "string"
    },
    "cardStyleVariant": {
      "type": "string"
    },
    "badgeStyleVariant": {
      "type": "string"
    },
    "campaign": {
      "type": "string"
    },
    "notificationCtaText": {
      "type": "string"
    },
    "notificationCtaLink": {
      "type": "string"
    },
    "seasonalTheme": {
      "type": "enumeration",
      "enum": [
        "default",
        "christmas",
        "halloween",
        "newyear"
      ],
      "default": "default"
    },
    "themeMode": {
      "type": "enumeration",
      "enum": [
        "auto",
        "manual"
      ],
      "default": "auto"
    },
    "autoThemeEnabled": {
      "type": "boolean",
      "default": true
    },
    "manualThemeOverride": {
      "type": "enumeration",
      "enum": [
        "default",
        "christmas",
        "halloween",
        "newyear"
      ]
    },
    "seasonalStartAt": {
      "type": "datetime"
    },
    "seasonalEndAt": {
      "type": "datetime"
    },
    "heroSeasonalVariant": {
      "type": "string"
    },
    "illustrationSeasonalVariant": {
      "type": "string"
    },
    "loadingAnimationVariant": {
      "type": "string"
    },
    "scrollAnimationVariant": {
      "type": "string"
    },
    "sectionStyleVariant": {
      "type": "string"
    },
    "seasonalBadgeVariant": {
      "type": "string"
    },
    "seasonalBackgroundVariant": {
      "type": "string"
    },
    "seasonalCampaign": {
      "type": "json"
    },
    "themeAppliedSites": {
      "type": "json"
    },
    "newyearIntroEnabled": {
      "type": "boolean",
      "default": true
    },
    "omikujiEnabled": {
      "type": "boolean",
      "default": true
    },
    "omikujiMessages": {
      "type": "json"
    },
    "omikujiVisualVariant": {
      "type": "string"
    },
    "perYearEventKey": {
      "type": "string"
    },
    "firstVisitOnlyEnabled": {
      "type": "boolean",
      "default": true
    }
  }
}
