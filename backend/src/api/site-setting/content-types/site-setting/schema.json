{
  "kind": "singleType",
  "collectionName": "site_setting",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Settings",
    "description": "Global site settings / サイト全体設定"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "logoUrl": {
      "type": "string"
    },
    "heroTitle": {
      "type": "string"
    },
    "heroSubtitle": {
      "type": "text"
    },
    "heroCTALabel": {
      "type": "string"
    },
    "heroCTAUrl": {
      "type": "string"
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "socialInstagram": {
      "type": "string"
    },
    "socialX": {
      "type": "string"
    },
    "socialYoutube": {
      "type": "string"
    },
    "announcementText": {
      "type": "string"
    },
    "announcementUrl": {
      "type": "string"
    },
    "announcementLevel": {
      "type": "enumeration",
      "enum": [
        "info",
        "urgent"
      ],
      "default": "info"
    }
  }
}
