{
  "kind": "collectionType",
  "collectionName": "lifecycle_templates",
  "info": {
    "singularName": "lifecycle-template",
    "pluralName": "lifecycle-templates",
    "displayName": "LifecycleTemplate"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "key": { "type": "uid", "required": true },
    "label": { "type": "string", "required": true },
    "channel": { "type": "enumeration", "enum": ["in_app", "email"], "required": true },
    "sourceSite": { "type": "enumeration", "enum": ["main", "store", "fc", "cross"], "default": "cross", "required": true },
    "locale": { "type": "string", "default": "ja", "required": true },
    "membershipEligibility": { "type": "enumeration", "enum": ["all", "logged_in", "member", "premium"], "default": "all" },
    "segmentRule": { "type": "json" },
    "subject": { "type": "string" },
    "title": { "type": "string", "required": true },
    "body": { "type": "richtext", "required": true },
    "ctaLabel": { "type": "string" },
    "ctaHref": { "type": "string" },
    "throttleHours": { "type": "integer", "default": 24, "required": true },
    "requiredNotification": { "type": "boolean", "default": false, "required": true },
    "startAt": { "type": "datetime" },
    "endAt": { "type": "datetime" }
  }
}
