{
  "kind": "collectionType",
  "collectionName": "inquiry_submissions",
  "info": {
    "singularName": "inquiry-submission",
    "pluralName": "inquiry-submissions",
    "displayName": "Inquiry Submission"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "formType": {
      "type": "enumeration",
      "enum": ["contact", "request", "restock", "application", "entry", "collaboration", "event", "store_support", "fc_support"],
      "required": true
    },
    "inquiryCategory": { "type": "string" },
    "name": { "type": "string" },
    "companyOrOrganization": { "type": "string" },
    "email": { "type": "email", "required": true },
    "phone": { "type": "string" },
    "subject": { "type": "string" },
    "message": { "type": "text" },
    "attachments": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["files", "images"]
    },
    "attachmentCount": { "type": "integer", "default": 0 },
    "attachmentMetadata": { "type": "json" },
    "locale": { "type": "string", "default": "ja" },
    "sourcePage": { "type": "string" },
    "sourceSite": {
      "type": "enumeration",
      "enum": ["main", "store", "fc", "unknown"],
      "default": "unknown"
    },
    "authUserId": { "type": "string" },
    "status": {
      "type": "enumeration",
      "enum": ["new", "in_review", "waiting_reply", "replied", "closed", "spam", "failed"],
      "default": "new",
      "required": true
    },
    "priority": {
      "type": "enumeration",
      "enum": ["low", "normal", "high", "urgent"],
      "default": "normal"
    },
    "adminMemo": { "type": "text" },
    "internalTags": { "type": "json" },
    "submittedAt": { "type": "datetime", "required": true },
    "handledAt": { "type": "datetime" },
    "handler": { "type": "string" },
    "lastActionAt": { "type": "datetime" },
    "replyStatus": {
      "type": "enumeration",
      "enum": ["not_required", "pending", "replied", "failed"],
      "default": "pending"
    },
    "caseStatus": {
      "type": "enumeration",
      "enum": ["draft", "submitted", "triaging", "waiting_user", "in_progress", "resolved", "closed", "reopened"],
      "default": "submitted",
      "required": true
    },
    "caseResolutionState": {
      "type": "enumeration",
      "enum": ["unresolved", "self_resolved", "support_resolved", "info_only", "duplicate", "escalated"],
      "default": "unresolved",
      "required": true
    },
    "caseVisibilityState": {
      "type": "enumeration",
      "enum": ["private_user", "support_only", "internal_only", "linked_article_only"],
      "default": "private_user",
      "required": true
    },
    "selfServiceState": {
      "type": "enumeration",
      "enum": ["not_attempted", "article_suggested", "article_viewed", "self_resolved", "still_need_support"],
      "default": "still_need_support",
      "required": true
    },
    "firstResponseAt": { "type": "datetime" },
    "resolvedAt": { "type": "datetime" },
    "lastUserActionAt": { "type": "datetime" },
    "lastSupportActionAt": { "type": "datetime" },
    "caseMetadata": { "type": "json" },
    "repliedAt": { "type": "datetime" },
    "ipHash": { "type": "string" },
    "userAgent": { "type": "string" },
    "policyAgree": { "type": "boolean", "default": false, "required": true },
    "consentTextVersion": { "type": "string" },
    "spamFlag": { "type": "boolean", "default": false },
    "spamScore": { "type": "integer", "default": 0 },
    "spamReason": { "type": "string" },
    "meta": { "type": "json" }
  }
}
