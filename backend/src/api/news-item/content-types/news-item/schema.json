{
  "kind": "collectionType",
  "collectionName": "news_items",
  "info": {
    "singularName": "news-item",
    "pluralName": "news-items",
    "displayName": "News",
    "description": "News / お知らせ"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "publishAt": {
      "type": "datetime"
    },
    "limitedEndAt": {
      "type": "datetime"
    },
    "archiveVisibleForFC": {
      "type": "boolean",
      "default": false
    },
    "body": {
      "type": "richtext"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "accessStatus": {
      "type": "enumeration",
      "enum": [
        "public",
        "fc_only",
        "limited"
      ],
      "default": "public",
      "required": true
    },
    "relatedProducts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::store-product.store-product"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "pickup": {
      "type": "boolean",
      "default": false
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "editorialWorkflowStatus": {
      "type": "enumeration",
      "enum": [
        "draft",
        "review_pending",
        "approved",
        "scheduled",
        "published",
        "archived",
        "expired"
      ],
      "default": "draft",
      "required": true
    },
    "editorialChecklist": {
      "type": "json"
    },
    "reviewComment": {
      "type": "text"
    },
    "approvedBy": {
      "type": "string"
    },
    "approvedAt": {
      "type": "datetime"
    },
    "scheduledPublishAt": {
      "type": "datetime"
    },
    "archiveAt": {
      "type": "datetime"
    },
    "qualityScore": {
      "type": "integer",
      "min": 0,
      "max": 100,
      "default": 0
    },
    "qualityWarnings": {
      "type": "json"
    },
    "translationCoverage": {
      "type": "json"
    }
  }
}
