{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "externalId": { "type": "string" },
    "orderNumber": { "type": "string", "unique": true },
    "provider": { "type": "enumeration", "enum": ["stripe"], "default": "stripe", "required": true },
    "sourceSite": { "type": "enumeration", "enum": ["main", "store", "fc", "cross"], "default": "store", "required": true },
    "orderStatus": { "type": "enumeration", "enum": ["draft", "placed", "confirmed", "canceled", "completed", "exception", "pending", "paid", "processing", "fulfilled", "failed"], "default": "placed", "required": true },
    "paymentStatus": { "type": "enumeration", "enum": ["pending", "authorized", "paid", "failed", "refunded", "partially_refunded", "succeeded", "canceled"], "default": "pending", "required": true },
    "fulfillmentStatus": { "type": "enumeration", "enum": ["unfulfilled", "preparing", "partially_fulfilled", "fulfilled", "failed"], "default": "unfulfilled", "required": true },
    "shipmentStatus": { "type": "enumeration", "enum": ["not_shipped", "shipped", "in_transit", "delivered", "returned", "failed"], "default": "not_shipped", "required": true },
    "returnStatus": { "type": "enumeration", "enum": ["none", "requested", "approved", "rejected", "received", "refunded"], "default": "none", "required": true },
    "refundStatus": { "type": "enumeration", "enum": ["none", "pending", "partially_refunded", "refunded", "failed"], "default": "none", "required": true },
    "inventoryReservationState": { "type": "enumeration", "enum": ["none", "reserved", "released", "expired"], "default": "none" },
    "inventoryCommitState": { "type": "enumeration", "enum": ["none", "committed", "rolled_back"], "default": "none" },
    "userId": { "type": "string" },
    "billingCustomerId": { "type": "string" },
    "customerId": { "type": "string" },
    "email": { "type": "email" },
    "checkoutSessionId": { "type": "string", "unique": true },
    "paymentIntentId": { "type": "string" },
    "currency": { "type": "string", "default": "JPY" },
    "amountTotal": { "type": "integer", "default": 0, "min": 0 },
    "subtotal": { "type": "integer", "default": 0, "min": 0 },
    "discountAmount": { "type": "integer", "default": 0, "min": 0 },
    "shippingFee": { "type": "integer", "default": 0, "min": 0 },
    "taxAmount": { "type": "integer", "default": 0, "min": 0 },
    "totalAmount": { "type": "integer", "default": 0, "min": 0 },
    "lineItems": { "type": "json" },
    "shippingAddress": { "type": "json" },
    "billingAddress": { "type": "json" },
    "fulfillmentMethod": { "type": "enumeration", "enum": ["shipping", "digital"], "default": "shipping" },
    "trackingNumber": { "type": "string" },
    "shippingCarrier": { "type": "string" },
    "estimatedDeliveryAt": { "type": "datetime" },
    "locale": { "type": "string", "default": "ja" },
    "campaignId": { "type": "string" },
    "loyaltyAppliedState": { "type": "string" },
    "supportState": { "type": "string" },
    "syncState": { "type": "enumeration", "enum": ["pending", "in_sync", "needs_manual_review", "failed"], "default": "pending" },
    "syncVersion": { "type": "integer", "default": 1, "min": 1 },
    "auditMetadata": { "type": "json" },
    "metadata": { "type": "json" },
    "orderedAt": { "type": "datetime" },
    "paidAt": { "type": "datetime" },
    "fulfilledAt": { "type": "datetime" },
    "deliveredAt": { "type": "datetime" },
    "canceledAt": { "type": "datetime" },
    "returnedAt": { "type": "datetime" },
    "webhookSyncedAt": { "type": "datetime" }
  }
}
