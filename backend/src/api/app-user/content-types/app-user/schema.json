{
  "kind": "collectionType",
  "collectionName": "app_users",
  "info": {
    "singularName": "app-user",
    "pluralName": "app-users",
    "displayName": "AppUser",
    "description": "認証ID（Supabase Auth中心）と mizzz 業務データを接続するユーザードメイン"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "appUserId": {
      "type": "uid",
      "targetField": "supabaseUserId",
      "required": true
    },
    "authIdentity": {
      "type": "enumeration",
      "enum": [
        "supabase",
        "logto"
      ],
      "default": "supabase",
      "required": true
    },
    "logtoUserId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "primaryEmail": {
      "type": "email"
    },
    "primaryPhone": {
      "type": "string"
    },
    "username": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "avatarUrl": {
      "type": "string"
    },
    "locale": {
      "type": "string",
      "default": "ja",
      "required": true
    },
    "timezone": {
      "type": "string"
    },
    "sourceSite": {
      "type": "enumeration",
      "enum": [
        "main",
        "store",
        "fc",
        "cross"
      ],
      "default": "cross",
      "required": true
    },
    "membershipStatus": {
      "type": "enumeration",
      "enum": [
        "non_member",
        "member",
        "grace",
        "canceled",
        "expired",
        "suspended",
        "guest",
        "active",
        "grace_period",
        "paused",
        "cancelled"
      ],
      "default": "non_member",
      "required": true
    },
    "membershipPlan": {
      "type": "enumeration",
      "enum": [
        "free",
        "standard",
        "premium"
      ],
      "default": "free",
      "required": true
    },
    "accessLevel": {
      "type": "enumeration",
      "enum": [
        "public",
        "logged_in",
        "member",
        "premium",
        "admin"
      ],
      "default": "logged_in",
      "required": true
    },
    "loyaltyState": {
      "type": "string",
      "default": "new"
    },
    "memberRankState": {
      "type": "enumeration",
      "enum": [
        "none",
        "starter",
        "core",
        "premium",
        "legacy",
        "honorary"
      ],
      "default": "none"
    },
    "rankTier": {
      "type": "enumeration",
      "enum": [
        "tier_0",
        "tier_1",
        "tier_2",
        "tier_3",
        "tier_4"
      ],
      "default": "tier_0"
    },
    "rankProgressState": {
      "type": "enumeration",
      "enum": [
        "not_started",
        "in_progress",
        "ready_to_unlock",
        "capped"
      ],
      "default": "not_started"
    },
    "streakState": {
      "type": "enumeration",
      "enum": [
        "none",
        "active",
        "at_risk",
        "broken"
      ],
      "default": "none"
    },
    "achievementState": {
      "type": "enumeration",
      "enum": [
        "none",
        "unlocked",
        "highlighted",
        "archived"
      ],
      "default": "none"
    },
    "missionState": {
      "type": "enumeration",
      "enum": [
        "available",
        "in_progress",
        "completed",
        "expired",
        "hidden"
      ],
      "default": "available"
    },
    "missionProgress": {
      "type": "integer",
      "default": 0
    },
    "perkState": {
      "type": "enumeration",
      "enum": [
        "none",
        "teaser",
        "available",
        "expiring",
        "locked"
      ],
      "default": "none"
    },
    "perkEligibility": {
      "type": "boolean",
      "default": false
    },
    "perkUnlockState": {
      "type": "enumeration",
      "enum": [
        "locked",
        "eligible",
        "unlocked",
        "claimed",
        "expired"
      ],
      "default": "locked"
    },
    "benefitVisibilityState": {
      "type": "enumeration",
      "enum": [
        "hidden",
        "teaser",
        "visible",
        "emphasized",
        "member_only"
      ],
      "default": "teaser"
    },
    "personalizationState": {
      "type": "enumeration",
      "enum": [
        "none",
        "basic",
        "member",
        "cross_site"
      ],
      "default": "basic"
    },
    "activitySummaryState": {
      "type": "enumeration",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "default": "low"
    },
    "nextUnlockHint": {
      "type": "text"
    },
    "lastProgressUpdateAt": {
      "type": "datetime"
    },
    "notificationPreference": {
      "type": "json",
      "required": true
    },
    "crmPreference": {
      "type": "json",
      "required": true
    },
    "profileCompletionState": {
      "type": "enumeration",
      "enum": [
        "empty",
        "partial",
        "complete"
      ],
      "default": "partial",
      "required": true
    },
    "onboardingState": {
      "type": "enumeration",
      "enum": [
        "not_started",
        "in_progress",
        "completed",
        "skipped"
      ],
      "default": "not_started",
      "required": true
    },
    "linkedProviders": {
      "type": "json",
      "required": true
    },
    "lastLoginAt": {
      "type": "datetime"
    },
    "firstLoginAt": {
      "type": "datetime"
    },
    "accountStatus": {
      "type": "enumeration",
      "enum": [
        "active",
        "pending",
        "restricted",
        "suspended",
        "deleted_like",
        "closed",
        "pending_review"
      ],
      "default": "active",
      "required": true
    },
    "mergeState": {
      "type": "enumeration",
      "enum": [
        "none",
        "candidate",
        "merged"
      ],
      "default": "none",
      "required": true
    },
    "supportFlags": {
      "type": "json",
      "required": true
    },
    "fieldSources": {
      "type": "json",
      "required": true
    },
    "lastSyncedAt": {
      "type": "datetime"
    },
    "syncVersion": {
      "type": "integer",
      "default": 1,
      "required": true
    },
    "joinedAt": {
      "type": "datetime"
    },
    "renewedAt": {
      "type": "datetime"
    },
    "canceledAt": {
      "type": "datetime"
    },
    "graceEndsAt": {
      "type": "datetime"
    },
    "suspendedAt": {
      "type": "datetime"
    },
    "reactivatedAt": {
      "type": "datetime"
    },
    "lifecycleStage": {
      "type": "enumeration",
      "enum": [
        "guest",
        "authenticated_non_member",
        "onboarding_user",
        "active_member",
        "grace_member",
        "inactive_member",
        "renewal_soon_member",
        "expired_member",
        "reactivated_member",
        "suspended_user"
      ],
      "default": "authenticated_non_member",
      "required": true
    },
    "entitlementState": {
      "type": "enumeration",
      "enum": [
        "none",
        "eligible",
        "active",
        "limited",
        "revoked"
      ],
      "default": "none",
      "required": true
    },
    "acquisitionSource": {
      "type": "string"
    },
    "lastRetentionMessageAt": {
      "type": "datetime"
    },
    "lastRenewalNoticeAt": {
      "type": "datetime"
    },
    "lastWinbackNoticeAt": {
      "type": "datetime"
    },
    "supabaseUserId": {
      "type": "string",
      "unique": true
    }
  }
}
