# ============================================================
# 環境変数テンプレート（開発環境用）
# このファイルを .env.local にコピーして実際の値を設定してください
# 本番環境は .env.production.example を参照してください
# ============================================================

# サイトURL（開発時はローカルURL）
VITE_SITE_URL=http://localhost:5173

# Strapi Cloud
VITE_STRAPI_API_URL=https://your-strapi-cloud-url.strapiapp.com
VITE_STRAPI_API_TOKEN=your_strapi_api_token_here


# CMS provider rollout (Strapi / WordPress staged cutover)
VITE_CMS_PROVIDER=strapi
VITE_WORDPRESS_API_URL=https://example.com/wp-json/creava/v1
VITE_CMS_WORDPRESS_ROLLOUT_ENABLED=false
VITE_CMS_WORDPRESS_ROLLOUT_SITE_MAIN=false
VITE_CMS_WORDPRESS_ROLLOUT_SITE_STORE=false
VITE_CMS_WORDPRESS_ROLLOUT_SITE_FC=false
VITE_CMS_WORDPRESS_ROLLOUT_BLOG=false
VITE_CMS_WORDPRESS_ROLLOUT_NEWS=false
VITE_CMS_WORDPRESS_ROLLOUT_EVENTS=false
VITE_CMS_WORDPRESS_ROLLOUT_WORKS=false
VITE_CMS_WORDPRESS_ROLLOUT_STORE=false
VITE_CMS_WORDPRESS_ROLLOUT_FANCLUB=false
VITE_CMS_WORDPRESS_ROLLOUT_SETTINGS=false
VITE_CMS_WORDPRESS_ROLLOUT_DISCOVERY_SEARCH=false
VITE_WORDPRESS_EDITORIAL_OPS_TIMEOUT_MS=8000
VITE_WORDPRESS_CAMPAIGN_ORCHESTRATION_ENABLED=true
VITE_WORDPRESS_RELEASE_SIMULATION_ENABLED=true
VITE_WORDPRESS_PLANNING_INTELLIGENCE_ENABLED=true
VITE_WORDPRESS_OPERATOR_COPILOT_ENABLED=true
VITE_WORDPRESS_SLA_PREDICTION_ENABLED=true
VITE_WORDPRESS_PUBLISH_RISK_MODEL_VERSION=v1
VITE_WORDPRESS_WORKLOAD_FORECAST_MODEL_VERSION=v1

# Unified Auth provider
VITE_AUTH_PROVIDER=supabase

# Supabase Auth（推奨）
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_OAUTH_DEFAULT_PROVIDER=google
VITE_SUPABASE_PROJECT_REF=your-project-ref
VITE_SUPABASE_PASSWORD_RESET_REDIRECT_URL=http://localhost:5173/callback?redirect=/member
VITE_SUPABASE_EMAIL_CHANGE_REDIRECT_URL=http://localhost:5173/member
VITE_SUPABASE_REAUTH_REDIRECT_URL=http://localhost:5173/member
VITE_SUPABASE_SECURITY_HUB_PATH=/member
VITE_SECURITY_RECENT_ACTIVITY_LIMIT=20
VITE_PRIVACY_CENTER_ENABLED=true
VITE_PRIVACY_DELETION_CONFIRM_PHRASE=DELETE_MY_ACCOUNT
VITE_PRIVACY_EXPORT_EXPIRY_HOURS=72

# Logto（SPA）
VITE_LOGTO_ENDPOINT=https://auth.mizzz.jp
VITE_LOGTO_APP_ID_UNIFIED=your_logto_spa_app_id_unified_here
# 下記は移行期間の互換値（未設定を推奨）
VITE_LOGTO_APP_ID_MAIN=your_logto_spa_app_id_main_here
VITE_LOGTO_APP_ID_STORE=your_logto_spa_app_id_store_here
VITE_LOGTO_APP_ID_FC=your_logto_spa_app_id_fc_here
# 旧互換（上記サイト別ID未設定時のフォールバック）
VITE_LOGTO_APP_ID=
VITE_LOGTO_CALLBACK_PATH=/callback
VITE_LOGTO_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
VITE_LOGTO_API_RESOURCE=https://api.mizzz.jp
VITE_LOGTO_ACCOUNT_CENTER_URL=https://auth.mizzz.jp/account-center
VITE_LOGTO_ISSUER=https://your-tenant.logto.app/oidc
# 管理APIは custom domain ではなく default tenant endpoint を利用
VITE_LOGTO_MANAGEMENT_API_ENDPOINT=https://your-tenant.logto.app
VITE_USER_SYNC_ENABLED=true
VITE_USER_LIFECYCLE_ONBOARDING_ENABLED=true
VITE_ONBOARDING_REMINDER_DAYS=7
VITE_MEMBERSHIP_STATE_SYNC_INTERVAL_SEC=300
VITE_RENEWAL_REMINDER_DAYS=7
VITE_GRACE_RECOVERY_DAYS=5
VITE_WINBACK_WINDOW_DAYS=30
VITE_LIFECYCLE_MESSAGE_COOLDOWN_HOURS=48
VITE_MEMBER_BENEFIT_HUB_ENABLED=true
VITE_MEMBER_VALUE_PROMPT_COOLDOWN_HOURS=24
VITE_MEMBER_EARLY_ACCESS_TEASER_DAYS=5
VITE_MEMBER_GRACE_VALUE_MESSAGE_DAYS=7
VITE_MEMBER_RANK_MODEL_VERSION=v1
VITE_MEMBER_MISSION_DEFAULT_ENABLED=true
VITE_MEMBER_PROGRESS_HUB_ENABLED=true
VITE_MEMBER_NEXT_UNLOCK_HINT_ENABLED=true
VITE_MEMBER_PERSONALIZED_PERK_ENABLED=true
VITE_CAMPAIGN_ELIGIBILITY_RULESET_VERSION=v1
VITE_SEASONAL_PERK_ENGINE_ENABLED=true
VITE_PERSONALIZED_OFFER_ENGINE_ENABLED=true
VITE_PERSONALIZED_OFFER_COOLDOWN_HOURS=72
VITE_SEASONAL_PROMPT_COOLDOWN_HOURS=96
VITE_RECOMMENDATION_REFRESH_MINUTES=720
VITE_NOTIFICATION_CENTER_ENABLED=true
VITE_NOTIFICATION_IMPORTANT_MAX=20
VITE_NOTIFICATION_INBOX_PAGE_SIZE=20
VITE_NOTIFICATION_DIGEST_DEFAULT=weekly
VITE_SUPPORT_CENTER_HISTORY_PAGE_SIZE=6
VITE_SUPPORT_CENTER_SUGGESTION_MAX=4
VITE_HELP_SEARCH_MIN_QUERY_LENGTH=2
VITE_HELP_SEARCH_DEBOUNCE_MS=350
VITE_HELP_ASSISTANT_MIN_QUERY_LENGTH=4
VITE_HELP_ASSISTANT_MAX_CANDIDATES=3
VITE_PROACTIVE_SUPPORT_ENABLED=true
VITE_PROACTIVE_SUPPORT_MIN_SCORE=40
VITE_PROACTIVE_INTERVENTION_COOLDOWN_MINUTES=120
VITE_PROACTIVE_RANKING_STRATEGY=rule_based_v1
VITE_PROACTIVE_EXPERIMENT_DEFAULT_STATE=running
VITE_PROACTIVE_POLICY_DEFAULT_STATE=active
VITE_SUPPORT_LOCALE_DEFAULT=ja
VITE_SUPPORT_LOCALE_FALLBACK_CHAIN=ja,en,ko
VITE_SUPPORT_LOCALE_MIN_COVERAGE=0.6
VITE_SUPPORT_TRANSLATION_QA_ENABLED=true
VITE_SUPPORT_LOCALE_ANALYTICS_ENABLED=true
VITE_SUPPORT_TRANSLATION_MEMORY_MIN_MATCH_SCORE=0.78
VITE_SUPPORT_TRANSLATION_WORKFLOW_AUTOMATION_ENABLED=true
VITE_SUPPORT_GLOSSARY_DRIFT_ALERT_THRESHOLD=0.2
VITE_SUPPORT_LOCALE_RETRIEVAL_LOW_CONFIDENCE_THRESHOLD=0.45
VITE_SUPPORT_REGIONAL_POLICY_TEMPLATE_DEFAULT=global-default-v1
VITE_SUPPORT_TRANSLATION_REUSE_HIGH_THRESHOLD=0.75
VITE_SUPPORT_LOCALE_RANKING_TUNING_TRIGGER=needs_tuning
VITE_SUPPORT_REGIONAL_POLICY_TEMPLATE_MIN_COVERAGE=0.8
VITE_SUPPORT_POLICY_GOVERNANCE_ENABLED=true
VITE_SUPPORT_GOVERNANCE_GUARDRAIL_WARN_THRESHOLD=0.45
VITE_SUPPORT_GOVERNANCE_GUARDRAIL_BREACH_THRESHOLD=0.3
VITE_STATUS_FETCH_TIMEOUT_MS=5000
VITE_STATUS_FETCH_RETRY_COUNT=1

# Logto ソーシャルログイン表示フラグ（Console 側設定と合わせる）
VITE_LOGTO_SOCIAL_GOOGLE_ENABLED=true
VITE_LOGTO_SOCIAL_APPLE_ENABLED=true
VITE_LOGTO_SOCIAL_X_ENABLED=true
VITE_LOGTO_SOCIAL_FACEBOOK_ENABLED=true

# Shopify Storefront API
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_token_here

# Inquiry API（Strapi 自前フォーム基盤）
# Contact / Request / Restock は Strapi の /api/inquiry-submissions/public に保存されます
# サイト種別（main / store / fc）。未指定時は unknown
VITE_SITE_TYPE=main

# Google Analytics 4（任意）
# 無料の Google Analytics で計測する場合に設定してください（Cookie 同意が必要）
# 形式: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=
# Google Tag Manager（任意）
# 形式: GTM-XXXXXXX
VITE_GTM_CONTAINER_ID=
# GA4 / GTM debug を有効化する（local/staging 推奨）
VITE_ANALYTICS_DEBUG_MODE=false
# analytics consent mode（v2）
VITE_ANALYTICS_CONSENT_MODE=v2
# analytics event mirror (任意: Strapiへ主要イベントを保存)
VITE_ANALYTICS_OPS_ENDPOINT=https://your-strapi-cloud-url.strapiapp.com/api/analytics-events/public
VITE_ANALYTICS_FOUNDATION_ENABLED=true
VITE_ANALYTICS_TAXONOMY_VERSION=2026-04-22
VITE_ANALYTICS_SESSION_TIMEOUT_MINUTES=30
VITE_ANALYTICS_REQUIRED_EVENT_STREAM=product_security_ops
VITE_ANALYTICS_OPTIONAL_EVENT_STREAM=product_marketing
VITE_ANALYTICS_ATTRIBUTION_MODEL=last_touch
VITE_ANALYTICS_FUNNEL_STRICT_MODE=true
VITE_ANALYTICS_EXPERIMENT_TRACKING_ENABLED=true
VITE_EXPERIMENT_RUNTIME_ENABLED=true
VITE_EXPERIMENT_DEFAULT_ROLLOUT_PERCENT=50
VITE_EXPERIMENT_DECISION_REVIEW_REQUIRED=true
VITE_EXPERIMENT_GUARDRAIL_AUTO_PAUSE=true
VITE_EXPERIMENT_TRAFFIC_ALLOWLIST=production
VITE_EXPERIMENT_EXCLUDE_PREVIEW=true
VITE_EXPERIMENT_EXCLUDE_INTERNAL=true
VITE_EXPERIMENT_EXCLUDE_BOT=true
VITE_ANALYTICS_OBSERVABILITY_ENABLED=true

VITE_CLARITY_PROJECT_ID=
VITE_CLARITY_SAMPLE_RATE=1
VITE_CLARITY_MASKING_MODE=strict
VITE_CLARITY_ALLOWED_PATHS=/,/store,/fanclub,/support
VITE_ANALYTICS_ALERT_WEBHOOK_URL=
VITE_ANALYTICS_ALERT_MIN_SESSIONS=200
VITE_ANALYTICS_ALERT_DROP_THRESHOLD=0.3
VITE_ANALYTICS_ALERT_SPIKE_THRESHOLD=0.45
VITE_ANALYTICS_ALERT_COOLDOWN_MINUTES=120
VITE_ANALYTICS_WEEKLY_REPORT_DAY=mon
VITE_ANALYTICS_MONTHLY_REPORT_DAY=1
VITE_LOOKER_STUDIO_DASHBOARD_URL=
VITE_SEARCH_CONSOLE_PROPERTY_MAIN=sc-domain:mizzz.jp
VITE_SEARCH_CONSOLE_PROPERTY_STORE=https://store.mizzz.jp/
VITE_SEARCH_CONSOLE_PROPERTY_FC=https://fc.mizzz.jp/


# Stripe (frontend は publishable key のみ設定)
# staging は pk_test_*, production は pk_live_* を設定する
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Personalization（お気に入り/履歴/通知）
# localStorage保存件数や同期を後で切り替えるためのフラグ
VITE_PERSONALIZATION_MAX_HISTORY=60
VITE_PERSONALIZATION_MAX_FAVORITES=120
VITE_PERSONALIZATION_RUNTIME_ENABLED=true
VITE_PERSONALIZATION_DEFAULT_HOLDOUT_RATE=10
VITE_PERSONALIZATION_REGISTRY_VERSION=2026-04-24
VITE_PERSONALIZATION_EXCLUDE_INTERNAL=true
VITE_PERSONALIZATION_EXCLUDE_PREVIEW=true
VITE_PERSONALIZATION_EXCLUDE_BOT=true
VITE_PERSONALIZATION_DEBUG=false
VITE_ENGAGEMENT_CENTER_ENABLED=true
VITE_ENGAGEMENT_MAX_ACTIVITY_ITEMS=120
VITE_ENGAGEMENT_MAX_CONTINUE_ITEMS=30
VITE_ENGAGEMENT_ALLOW_NATIVE_SHARE=true
VITE_ENGAGEMENT_ALLOW_GUEST_PERSISTENCE=true
VITE_ENGAGEMENT_SYNC_ENDPOINT=
VITE_ENGAGEMENT_SYNC_TIMEOUT_MS=4000
VITE_ENGAGEMENT_SYNC_RETRY=1

# PWA / Web Push
VITE_ENABLE_PWA=true
VITE_WEB_PUSH_VAPID_PUBLIC_KEY=

# Member / internal order operations
VITE_MEMBER_ORDER_LOOKUP_ENABLED=true
VITE_INTERNAL_ORDER_LOOKUP_ENABLED=true
VITE_INTERNAL_ADMIN_CONSOLE_ENABLED=true
VITE_INTERNAL_ADMIN_USER360_TIMELINE_LIMIT=80
VITE_RUNTIME_EXPOSURE_CONTROL_ENABLED=true
VITE_FLAG_DASHBOARD_ENABLED=true
VITE_FLAG_EVALUATION_CACHE_TTL_SEC=120
VITE_FLAG_KILL_SWITCH_CONFIRM_REQUIRED=true

# CMS preview / publish workflow
# 推奨: secret を frontend に露出しないため verify endpoint を利用
VITE_PREVIEW_VERIFY_ENDPOINT=http://localhost:1337/api/cms-sync/preview/verify
VITE_WORDPRESS_PREVIEW_VERIFY_ENDPOINT=https://example.com/wp-json/creava/v1/preview/verify
# 互換 fallback（verify endpoint 未導入時のみ使用）
VITE_PREVIEW_SECRET=
